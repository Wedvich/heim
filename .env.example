# PostgreSQL (used by compose.yml via packages/infra)
POSTGRES_USER=heim
POSTGRES_PASSWORD=heim
POSTGRES_DB=heim
POSTGRES_PORT=5432

# API
DATABASE_URL=postgres://heim:heim@localhost:5432/heim
DEV_AUTH_BYPASS=true

# Web (VITE_ prefix required for client-side access)
VITE_API_URL=http://localhost:3000
