{
  "$schema": "node_modules/turbo/schema.json",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "interactive": true,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    },
    "test:watch": {
      "cache": false,
      "dependsOn": ["^build"],
      "interactive": true,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    }
  }
}
